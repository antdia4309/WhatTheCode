@page "/"
@page "/sandbox"
@rendermode @(new InteractiveServerRenderMode())
@using WhatTheCode.Models
@using WhatTheCode.Services
@using WhatTheCode.Components
@using Microsoft.AspNetCore.Components.Web

<PageTitle>What the CODE?</PageTitle>

<div class="sandbox-container">

    <header class="sandbox-header">
        <h1>🎮 What the CODE?</h1>
        <p class="subtitle">Session 1 — Command your bot across the grid!</p>
    </header>

    <div class="sandbox-body">

        <!-- GRID -->
        <div class="grid-wrapper">
            <GameGrid Grid="_grid" Character="_character" />
            <p class="status @(_lastResult?.Success == false ? "status-error" : "status-ok")">
                @_statusMessage
            </p>
        </div>

        <!-- CONTROLS -->
        <div class="controls-panel">

            <h2>🕹️ Block Commands</h2>
            <p class="hint">Click the blocks to move your bot.</p>

            <div class="command-buttons">
                <button class="cmd-btn" @onclick="@(() => RunCommand("MoveForward"))">
                    ⬆️ Move Forward
                </button>
                <button class="cmd-btn" @onclick="@(() => RunCommand("TurnLeft"))">
                    ↩️ Turn Left
                </button>
                <button class="cmd-btn" @onclick="@(() => RunCommand("TurnRight"))">
                    ↪️ Turn Right
                </button>
            </div>

            <hr />

            <!-- CODE BRIDGE (shows the C# behind the button) -->
            <div class="bridge-panel">
                <h3>🔍 What's the code doing?</h3>
                <pre class="code-preview">@_codePreview</pre>
            </div>

            <button class="reset-btn" @onclick="@(() => RunCommand("Reset"))">
                🔄 Reset Grid
            </button>

        </div>
    </div>
</div>

@code {
    private Grid      _grid      = new Grid(8, 8);
    private Character _character = new Character(0, 0, Direction.Right);
    private CommandEngine _engine = default!;

    private CommandResult? _lastResult;
    private string _statusMessage = "Ready. Give your bot a command!";
    private string _codePreview   = "// Click a command to see the code...";

    protected override void OnInitialized()
    {
        _engine = new CommandEngine(_grid, _character);
        _grid.MarkVisited(0, 0);
    }

    private void RunCommand(string command)
    {
        _lastResult    = _engine.Execute(command);
        _statusMessage = _lastResult.Message;
        _codePreview   = GetCodePreview(command);
    }

    private string GetCodePreview(string command) => command switch
    {
        "MoveForward" =>
            "// Character.cs\npublic bool MoveForward(int cols, int rows)\n{\n    // Calculates next position\n    // based on current Direction\n    // Returns false if out of bounds\n}",
        "TurnLeft"  =>
            "// Character.cs\npublic void TurnLeft()\n{\n    // Rotates Direction\n    // Up → Left → Down → Right\n}",
        "TurnRight" =>
            "// Character.cs\npublic void TurnRight()\n{\n    // Rotates Direction\n    // Up → Right → Down → Left\n}",
        "Reset" =>
            "// CommandEngine.cs\nprivate CommandResult HandleReset()\n{\n    _character.Reset(0, 0);\n    _grid.Reset();\n    return new CommandResult { Success = true };\n}",
        _ => "// Unknown command"
    };
}

<style>
    .sandbox-container {
        min-height: 100vh;
        background: #0d0d1a;
        color: #e0e0ff;
        font-family: 'Segoe UI', sans-serif;
        padding: 2rem;
    }

    .sandbox-header {
        text-align: center;
        margin-bottom: 2rem;
    }

    .sandbox-header h1 {
        font-size: 2.5rem;
        color: #00d4ff;
        margin: 0;
    }

    .subtitle {
        color: #8888aa;
        margin-top: 0.3rem;
    }

    .sandbox-body {
        display: flex;
        gap: 2rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .controls-panel {
        background: #16213e;
        border: 1px solid #0f3460;
        border-radius: 12px;
        padding: 1.5rem;
        min-width: 280px;
        max-width: 340px;
    }

    .controls-panel h2 { color: #00d4ff; margin-top: 0; }
    .hint { color: #8888aa; font-size: 0.85rem; margin-top: -0.5rem; }

    .command-buttons {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        margin: 1rem 0;
    }

    .cmd-btn {
        background: #0f3460;
        color: #e0e0ff;
        border: 1px solid #00d4ff44;
        border-radius: 8px;
        padding: 0.75rem 1rem;
        font-size: 1rem;
        cursor: pointer;
        transition: background 0.15s, border-color 0.15s;
        text-align: left;
    }

    .cmd-btn:hover {
        background: #00d4ff22;
        border-color: #00d4ff;
    }

    .bridge-panel {
        background: #0d0d1a;
        border-radius: 8px;
        padding: 1rem;
        margin: 1rem 0;
    }

    .bridge-panel h3 { color: #ffcc00; font-size: 0.9rem; margin: 0 0 0.5rem 0; }

    .code-preview {
        font-family: 'Courier New', monospace;
        font-size: 0.78rem;
        color: #00ff88;
        white-space: pre-wrap;
        margin: 0;
        line-height: 1.5;
    }

    .reset-btn {
        width: 100%;
        background: transparent;
        border: 1px solid #ff4466;
        color: #ff4466;
        border-radius: 8px;
        padding: 0.6rem;
        cursor: pointer;
        transition: background 0.15s;
    }

    .reset-btn:hover { background: #ff446622; }

    .status {
        margin-top: 0.75rem;
        font-size: 0.85rem;
        text-align: center;
        padding: 0.4rem 0.8rem;
        border-radius: 6px;
        background: #16213e;
    }

    .status-ok    { color: #00ff88; }
    .status-error { color: #ff4466; }
</style>